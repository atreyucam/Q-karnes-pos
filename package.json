{
  "name": "qkarnes-pos",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/api",
    "apps/desktop"
  ],
  "scripts": {
    "dev:api": "npm --workspace apps/api run dev",
    "dev:desktop": "npm --workspace apps/desktop run dev",
    "electron:dev": "npm --workspace apps/desktop run electron:dev",
    "build:web-local": "npm --workspace apps/desktop run build:web-local",
    "start:web-local": "node scripts/start-web-local.cjs",
    "dev:web-local": "npm run build:web-local && npm run start:web-local",
    "package:web-local": "node scripts/package-web-local.cjs",
    "install:linux": "bash scripts/install-linux.sh",
    "uninstall:linux": "bash scripts/uninstall-linux.sh",
    "install:antix": "bash scripts/install-antix.sh",
    "uninstall:antix": "bash scripts/uninstall-antix.sh",
    "preflight:local": "node scripts/preflight-local.cjs",
    "dev:local": "node scripts/dev-local.cjs",
    "prepare:local": "npm --workspace apps/api run migrate",
    "build:local": "npm run preflight:local && npm --workspace apps/desktop run build",
    "start:local": "node scripts/start-local.cjs",
    "check:local": "node scripts/check-local.cjs",
    "db:paths": "npm --workspace apps/api run db:paths",
    "diagnose:local": "npm --workspace apps/api run support:diagnose",
    "support:export": "npm --workspace apps/api run support:export",
    "backup:local": "npm --workspace apps/api run support:backup",
    "restore:local": "npm --workspace apps/api run support:restore",
    "test:modulo1": "npm --workspace apps/api run test:modulo1",
    "test:modulo2": "npm --workspace apps/api run test:modulo2",
    "test:modulo2:frontend": "npm --workspace apps/desktop run test:modulo2:frontend",
    "test:modulo3": "npm --workspace apps/api run test:modulo3",
    "test:modulo4": "npm --workspace apps/api run test:modulo4",
    "test:modulo5": "npm --workspace apps/api run test:modulo5",
    "test:modulo6": "npm --workspace apps/api run test:modulo6",
    "test:modulo7": "npm --workspace apps/api run test:modulo7",
    "test:modulo8": "npm --workspace apps/api run test:modulo8",
    "test:operacion": "npm --workspace apps/api run test:operacion",
    "test:regression": "npm --workspace apps/api run test:regression",
    "test:bloque6": "npm --workspace apps/desktop run test:bloque6",
    "test:frontend:build": "npm --workspace apps/desktop run build",
    "test:bloque7": "node scripts/bloque7-operacion-tests.cjs",
    "test:bloque8": "node scripts/bloque8-soporte-tests.cjs",
    "test:bloque9:frontend": "npm --workspace apps/desktop run test:bloque9",
    "test:sidebar:final": "npm --workspace apps/desktop run test:sidebar:final",
    "test:reportes:frontend": "npm --workspace apps/desktop run test:reportes",
    "test:ticket:frontend": "npm --workspace apps/desktop run test:ticket"
  }
}
