PORT=4100
# JWT_SECRET obligatorio fuera de development/test.
# Use al menos 32 caracteres y nunca valores conocidos.
JWT_SECRET=replace-with-a-very-long-random-secret-32-plus-chars
JWT_EXPIRES_IN=8h
# DB_FILE opcional.
# - development/test: por defecto ./data/qkarnes.sqlite (o qkarnes.test.sqlite en test)
# - production: por defecto en carpeta de datos de usuario del sistema operativo.
# Ejemplo custom: DB_FILE=C:\\QKarnesData\\qkarnes.sqlite
DB_FILE=./data/qkarnes.sqlite
TZ=America/Guayaquil
ALLOW_DEMO_SEED=false
# Nivel de logs: debug|info|warn|error|critical
LOG_LEVEL=info
